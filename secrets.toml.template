# Copy this locally to .streamlit/secrets.toml for testing.
# On Streamlit Community Cloud, paste the same format into Advanced settings -> Secrets.

# Use whichever provider(s) you want. You do NOT need all of them.

ANTHROPIC_API_KEY = "your-anthropic-key-here"
OPENAI_API_KEY = "your-openai-key-here"
GOOGLE_API_KEY = "your-google-ai-studio-key-here"
GROQ_API_KEY = "your-groq-key-here"
